# ===========================================
# VoxVertex Connect – environment template
# ===========================================
# Copy to .env and fill in values. Do not commit .env.

# ---------- Backend (apps/backend) ----------
PORT=5000
# MongoDB: use Atlas connection string or local
# Example: mongodb+srv://user:pass@cluster.mongodb.net/voxvertex?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/voxvertex

# Optional: set to "aws" when migrating DB to DynamoDB/DocumentDB (requires userRepository.aws.js)
# DB_ADAPTER=mongodb

# ---------- Frontend (apps/frontend) ----------
# Only needed for production build when API is on a different origin. Leave empty for same-origin or proxy.
# VITE_API_URL=https://api.yourdomain.com
